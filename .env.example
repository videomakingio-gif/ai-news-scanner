# Required: at least one LLM API key based on your provider choice
# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (if using provider: "openai")
# OPENAI_API_KEY=sk-your-key-here

# Google Gemini (if using provider: "gemini")
# GEMINI_API_KEY=your-key-here

# Optional: path to custom config (default: ./config.yaml)
# CONFIG_PATH=./my-config.yaml

# Optional: for GCS backend
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional: Telegram notifications
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=123456789

# Optional: Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxx
